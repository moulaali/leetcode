import java.util.HashMap;
import java.util.Map;

/**
 * Given an array of integers nums and an integer k, return the total number of subarrays whose sum equals to k.
 *
 * A subarray is a contiguous non-empty sequence of elements within an array.
 *
 *
 *
 * Example 1:
 *
 * Input: nums = [1,1,1], k = 2
 * Output: 2
 * Example 2:
 *
 * Input: nums = [1,2,3], k = 3
 * Output: 2
 *
 * Approach : keep a cummilative sum of elements from 0th index to i while scanning from left to right
 * see if there is sum of (targetSum - curSum) in map to detect the subarray.
 */
public class SubarrayWithSumK {

    public static void main(String[] args) {
        // getSubArraysCountWithSumK(new int[]{5, 2, 6, 11, 1, 3, 8}, 8);
        getSubArraysCountWithSumK(new int[]{0, 0, 0}, 0);
    }

    static int getSubArraysCountWithSumK(int[] a, int target) {
        Map<Integer, Integer> cumSumMap = new HashMap<>();

        int curSum = 0;
        int count = 0;
        for (int i = 0; i < a.length; i++) {
            System.out.println("-----");
            curSum += a[i];
            System.out.println("curSum at " + a[i] + " " + curSum);

            if (curSum == target) {
                count++;
                cumSumMap.put(curSum, i);
                System.out.println("Found a sub-array at 0 to " + a[i]);
                continue;
            }

            // see if there is target - curSum in map
            Integer pos = cumSumMap.get(curSum - target);
            if (pos != null) {
                System.out.println("Found a sub-array from " + a[pos + 1] + " and " + a[i]);
                count++;
            }
            cumSumMap.put(curSum, i);
        }

        System.out.println("Count : " + count);
        return count;
    }
}
